DATABASE_URL="postgresql://pokemon_watcher:pokemon_watcher@localhost:5432/pokemon_watcher?schema=public"
REDIS_URL="redis://localhost:6379"

LOG_LEVEL=info
LOG_FILE=data/events.log

# ntfy.sh push notifications.
# DEPRECATED: these values are no longer read. Configure server + topics via the
# Settings tab in the WebApp instead (stored in the Setting table, key=ntfyConfig).
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=

# WebApp-UI (HTTP Basic Auth). Leave WEB_PASSWORD empty to disable the UI.
WEB_PORT=3000
WEB_USERNAME=admin
WEB_PASSWORD=change-me
