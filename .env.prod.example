# Production env for docker-compose.prod.yml
# Copy to .env on the server and fill in real values.

POSTGRES_USER=pokemon_watcher
POSTGRES_PASSWORD=CHANGE_ME_to_a_long_random_string
POSTGRES_DB=pokemon_watcher

LOG_LEVEL=info

# NTFY-Topic wird ab v0.2 nicht mehr aus .env gelesen.
# Konfiguration erfolgt im Settings-Tab der WebApp (Setting-Tabelle, Key=ntfyConfig).
# Diese Variablen bleiben nur für Abwärtskompatibilität/Doku stehen.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=

# WebApp-UI (HTTP Basic Auth)
WEB_PORT=3000
WEB_USERNAME=admin
WEB_PASSWORD=CHANGE_ME_to_a_long_random_string
