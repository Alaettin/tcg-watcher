# Production env for docker-compose.prod.yml
# Copy to .env on the server and fill in real values.

POSTGRES_USER=pokemon_watcher
POSTGRES_PASSWORD=CHANGE_ME_to_a_long_random_string
POSTGRES_DB=pokemon_watcher

LOG_LEVEL=info

# NTFY-Push wird ab v0.2 im Settings-Tab der WebApp konfiguriert (DB-managed).

# WebApp HTTP Basic Auth
WEB_USERNAME=admin
WEB_PASSWORD=CHANGE_ME_to_a_long_random_string

# Port binding
# - WEB_PORT: port inside the container (don't change unless you know why)
# - HOST_PORT: port exposed on the host — pick anything free on your VPS
# - BIND_HOST: 127.0.0.1 keeps the app private (front with Caddy/nginx). Use
#   0.0.0.0 only if you want the app reachable directly from the internet.
WEB_PORT=3000
HOST_PORT=3030
BIND_HOST=127.0.0.1
