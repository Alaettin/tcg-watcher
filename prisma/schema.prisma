generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                  String    @id
  displayName         String
  category            String
  expectedReleaseDate DateTime?
  uvpEur              Float?
  uvpToleranceEur     Float     @default(10)
  searchTerms         String[]
  negativeTerms       String[]
  ean                 String?
  minResalePriceEur   Float?
  active              Boolean   @default(true)
  listings            Listing[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Shop {
  id                     String    @id
  displayName            String
  baseUrl                String
  adapterType            String
  enabled                Boolean   @default(true)
  pollIntervalSeconds    Int       @default(120)
  dropDayIntervalSeconds Int       @default(10)
  setListId              String?
  setList                SetList?  @relation(fields: [setListId], references: [id], onDelete: SetNull)
  listings               Listing[]
  lastSuccessfulRun      DateTime?
  lastRunStats           Json?

  @@index([setListId])
}

model Listing {
  id         String        @id @default(cuid())
  productId  String?
  setId      String?
  variantId  String?
  shopId     String
  externalId String
  url        String
  title      String
  priceEur   Float
  currency   String        @default("EUR")
  status     ListingStatus
  seenAt     DateTime      @default(now())
  product    Product?      @relation(fields: [productId], references: [id])
  set        Set?          @relation(fields: [setId], references: [id])
  variant    Variant?      @relation(fields: [variantId], references: [id])
  shop       Shop          @relation(fields: [shopId], references: [id])
  events     Event[]

  @@unique([shopId, externalId])
  @@index([productId, status])
  @@index([setId, status])
  @@index([seenAt])
}

model Set {
  id              String        @id
  name            String
  shortCode       String?
  description     String?
  releaseDate     DateTime?
  language        String        @default("DE")
  era             String?
  searchTerms     String[]
  negativeTerms   String[]
  // active is deprecated — set-tracking is now controlled by SetList
  // membership. Kept for backwards-compat, dropped in a later migration.
  active          Boolean       @default(false)
  isPreset        Boolean       @default(false)
  variants        Variant[]
  listings        Listing[]
  listMemberships SetListItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([active])
  @@index([era])
}

model SetList {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  isSystem    Boolean       @default(false)
  items       SetListItem[]
  shops       Shop[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model SetListItem {
  setListId String
  setId     String
  setList   SetList @relation(fields: [setListId], references: [id], onDelete: Cascade)
  set       Set     @relation(fields: [setId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([setListId, setId])
  @@index([setId])
}

model Variant {
  id              String    @id @default(cuid())
  setId           String
  kind            String
  displayName     String
  uvpEur          Float?
  uvpToleranceEur Float     @default(10)
  ean             String?
  set             Set       @relation(fields: [setId], references: [id], onDelete: Cascade)
  listings        Listing[]

  @@index([setId])
}

enum ListingStatus {
  IN_STOCK
  OUT_OF_STOCK
  PREORDER
  UNKNOWN
}

model Event {
  id         String    @id @default(cuid())
  listingId  String
  type       EventType
  detail     Json
  notifiedAt DateTime?
  createdAt  DateTime  @default(now())
  listing    Listing   @relation(fields: [listingId], references: [id])

  @@index([type, createdAt])
}

enum EventType {
  NEW_LISTING
  RESTOCK
  PRICE_DROP
  RESALE_DEAL
  WENT_OUT_OF_STOCK
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Offline / brick-and-mortar deal tracking (marktguru, bonial, …).
// Strictly separated from the Online listing models above.
model OfflineRetailer {
  id          String        @id          // "rewe", "kaufland", "lidl", "mediamarkt"
  displayName String                       // "REWE", "Kaufland", "Lidl"
  source      String?                      // optional: marktguru advertiser-id, e.g. "retailers/126654"
  logoUrl     String?
  deals       OfflineDeal[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model OfflineDeal {
  id               String           @id @default(cuid())
  source           String                            // "marktguru" | "bonial"
  sourceDealId     String                            // ID von der Quelle (zur Dedup)
  retailerId       String
  retailer         OfflineRetailer  @relation(fields: [retailerId], references: [id])
  title            String
  description      String?
  brand            String?
  imageUrl         String?
  category         String?
  priceEur         Float?
  originalPriceEur Float?
  validFrom        DateTime
  validUntil       DateTime
  sourceUrl        String?

  // optional Standort-Daten
  postalCode       String?
  storeName        String?
  storeAddress     String?
  storeCity        String?
  storeLat         Float?
  storeLng         Float?

  firstSeenAt      DateTime         @default(now())
  lastSeenAt       DateTime
  events           OfflineEvent[]

  @@unique([source, sourceDealId])
  @@index([retailerId])
  @@index([validUntil])
  @@index([firstSeenAt])
}

model OfflineEvent {
  id         String      @id @default(cuid())
  dealId     String
  deal       OfflineDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type       String                          // NEW_DEAL | PRICE_DROP | EXPIRING_SOON | WENT_AWAY
  detail     Json
  notifiedAt DateTime?
  createdAt  DateTime    @default(now())

  @@index([type, createdAt])
  @@index([dealId])
}

// Cardmarket Bulk-Import. Komplett getrennt vom Online-Listing-System.
// Daten kommen aus downloads.s3.cardmarket.com/productCatalog/* (öffentlich,
// täglich neu generiert). 2 Quellen: products_nonsingles_6.json (Sealed-
// Stammdaten, ~4800 Records), price_guide_6.json (Preise für Singles +
// Sealed, ~75000 Records).
model CardmarketProduct {
  idProduct    Int               @id           // CM's interne product-ID
  name         String                           // "151 Elite Trainer Box"
  idCategory   Int                              // 1016 = "Pokémon Elite Trainer Boxes"
  categoryName String                           // human-readable Kategorie
  idExpansion  Int                              // 5402 = SV151 EN, 5328 = JP, ...
  idMetacard   Int               @default(0)
  dateAdded    DateTime?                        // CM's product-creation
  importedAt   DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  price        CardmarketPrice?
  snapshots    CardmarketPriceSnapshot[]
  signals      CardmarketSignal[]
  watchlistItem CardmarketWatchlistItem?

  @@index([idCategory])
  @@index([idExpansion])
  @@index([name])
}

model CardmarketPrice {
  idProduct  Int                @id
  product    CardmarketProduct? @relation(fields: [idProduct], references: [idProduct], onDelete: Cascade)
  idCategory Int                                 // wird mit-gespeichert weil Singles oft kein
                                                  // CardmarketProduct-Pendant haben (separate _singles_-Datei)
  avg        Float?
  low        Float?
  trend      Float?
  avg1       Float?
  avg7       Float?
  avg30      Float?
  avgHolo    Float?
  lowHolo    Float?
  trendHolo  Float?
  avg1Holo   Float?
  avg7Holo   Float?
  avg30Holo  Float?
  importedAt DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([idCategory])
  @@index([trend])
}

model CardmarketSyncStatus {
  id                    String   @id @default("singleton")
  productsLastSync      DateTime?
  productsLastSourceAt  DateTime?
  productsRecordCount   Int?
  pricesLastSync        DateTime?
  pricesLastSourceAt    DateTime?
  pricesRecordCount     Int?
  lastError             String?
  updatedAt             DateTime @updatedAt
}

// Append-only Tages-Schnappschuss aller Preise. Selbstgebaute Historie (cm.md §2.1)
// — Quelle für Δ7/Δ30, Chart-Linie und Backtest. Niemals löschen.
model CardmarketPriceSnapshot {
  id           BigInt   @id @default(autoincrement())
  idProduct    Int
  snapshotDate DateTime @db.Date
  low          Float?
  avg          Float?
  trend        Float?
  avg1         Float?
  avg7         Float?
  avg30        Float?
  createdAt    DateTime @default(now())
  product      CardmarketProduct @relation(fields: [idProduct], references: [idProduct], onDelete: Cascade)

  @@unique([idProduct, snapshotDate])
  @@index([snapshotDate])
  @@index([idProduct, snapshotDate(sort: Desc)])
}

// Vorberechnete Signale pro Produkt pro Tag (cm.md §5).
// Reasoning-Lines werden bei jedem Render aus Templates regeneriert — hier
// nur die Werte/Klassifikation, damit Schwellwert-Änderungen ohne Daten-
// Migration möglich sind (cm.md §14 Regel 4).
model CardmarketSignal {
  idProduct       Int
  snapshotDate    DateTime @db.Date
  lScore          Float?
  mScore          Float?
  delta7          Float?
  delta30         Float?
  movementClass   String?  // siehe signals/types.ts MovementClass
  recommendation  String   // GREEN | AMBER | RED | NEUTRAL
  headline        String
  reasoningLines  Json     // string[]
  sampleQuality   Float
  computedAt      DateTime @default(now())
  product         CardmarketProduct @relation(fields: [idProduct], references: [idProduct], onDelete: Cascade)

  @@id([idProduct, snapshotDate])
  @@index([snapshotDate, recommendation])
  @@index([snapshotDate, delta7])
  @@index([snapshotDate, mScore])
  @@index([idProduct, snapshotDate(sort: Desc)])
}

// Set-Stammdaten. Sprach-Pendant-Feature wurde in Phase 4 verworfen
// (JP/EN-Sets sind eigenständige Sammlerprodukte, kein Arbitrage-Use-Case);
// daher kein parentExpansionId-Mapping mehr.
model CardmarketExpansion {
  idExpansion  Int       @id
  name         String
  language     String    // EN|JP|DE|FR|IT|KR|ZH|PT — heute meist EN, weil CM keine zuverlässige Sprach-Quelle hat
  releaseDate  DateTime? @db.Date
  importedAt   DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([language])
}

// History der Sync-Runs (cm.md §6 Step 7). CardmarketSyncStatus bleibt das
// Singleton für die UI-Anzeige; dieser Log ist die volle Run-Historie.
model CardmarketSyncLog {
  id                    BigInt    @id @default(autoincrement())
  startedAt             DateTime
  finishedAt            DateTime?
  productsCount         Int?
  snapshotsCount        Int?
  signalsCount          Int?
  expansionsCount       Int?
  watchlistAlertsCount  Int?
  status                String    // running | ok | failed
  errorMsg              String?
  durationMs            Int?

  @@index([startedAt(sort: Desc)])
}

// Single-User-Watchlist (cm.md §5, Phase 3). Schwellwert-Alerts auf trend
// und Signal-Flip-Alerts. 24h-Cooldown via lastAlertSentAt — vermeidet
// Push-Spam falls trend tagelang unter Schwelle bleibt.
model CardmarketWatchlistItem {
  id                          BigInt   @id @default(autoincrement())
  idProduct                   Int      @unique
  product                     CardmarketProduct @relation(fields: [idProduct], references: [idProduct], onDelete: Cascade)
  note                        String?
  alertBelowTrend             Float?
  alertAboveTrend             Float?
  alertOnSignalFlip           Boolean  @default(true)
  lastAlertSentAt             DateTime?
  // Snapshot der zuletzt PER ALERT GEMELDETEN Empfehlung. Erlaubt Flip-
  // Detection ohne zweiten Signal-Query und ohne in der Engine eine
  // Zustands-Tabelle zu führen.
  lastNotifiedRecommendation  String?
  addedAt                     DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@index([addedAt(sort: Desc)])
}
